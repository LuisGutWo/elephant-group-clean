{
    "name": "elephant_group_website",
    "version": "0.1.0",
    "private": true,
    "engines": {
        "node": "20.x || 22.x || >=24.x"
    },
    "overrides": {
        "brace-expansion": "^1.1.13",
        "postcss": "^8.5.10"
    },
    "scripts": {
        "dev": "npm run dev:email & npm run dev:next",
