        "autoprefixer": "^10.4.23",
        "eslint": "^9",
        "eslint-config-next": "15.3.0",
        "postcss": "^8.5.10",
        "postcss-cli": "^11.0.1",
        "prettier": "^3.0.0-alpha.6"
