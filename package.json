        "gsap": "^3.13.0",
        "next": "^15.3.2",
        "next-sitemap": "^4.2.3",
        "nodemailer": "^9.0.1",
        "react": "^19.0.0",
        "react-bootstrap": "^2.10.10",
        "react-countup": "^6.5.3",
        "react-dom": "^19.0.0",
        "react-google-recaptcha": "^3.1.0",
        "react-icons": "^5.5.0",
        "react-scroll-parallax": "^3.4.5",
        "swiper": "^12.2.0",
        "xss": "^1.0.15"
    },
    "devDependencies": {
